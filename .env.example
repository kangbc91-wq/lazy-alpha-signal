# ===================================
# Lazy Alpha Signal Filter 설정
# ===================================
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요
# cp .env.example .env

# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 셔레그램 채팅 ID (아래 가이드 참고)
TELEGRAM_CHAT_ID=your_chat_id_here

# Webhook 보안 시크릿 키 (선택사항, 빈 값이면 검증 안 함)
WEBHOOK_SECRET=
